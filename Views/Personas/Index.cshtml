@{
    ViewData["Title"] = "Registro de Personas";
}

@* Token antiforgery usado por las peticiones AJAX (POST / DELETE). *@
@Html.AntiForgeryToken()

<div class="personas-page">
    <div class="page-header">
        <div>
            <h1 class="page-title">Registro de Personas</h1>
            <p class="page-subtitle">Administra los registros: crea, visualiza, edita y elimina sin recargar la página.</p>
        </div>
        <button type="button" class="btn btn-primary btn-nueva" id="btnNueva">
            <span class="ico">＋</span> Nueva persona
        </button>
    </div>

    <div class="toolbar">
        <div class="search-box">
            <span class="search-ico">🔎</span>
            <input type="search" id="buscador" class="form-control" placeholder="Buscar por apellido, nombre, dirección o sexo…" autocomplete="off" />
        </div>
        <span class="badge-total" id="contadorRegistros">0 registros</span>
    </div>

    <div class="card tabla-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Primer Apellido</th>
                        <th>Segundo Apellido</th>
                        <th>Nombres</th>
                        <th class="col-direccion">Dirección</th>
                        <th>Sexo</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody id="tablaPersonas">
                    <!-- Filas cargadas dinámicamente por AJAX -->
                </tbody>
            </table>
        </div>

        <div id="estadoCarga" class="estado-vacio d-none">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mb-0 mt-2 text-muted">Cargando registros…</p>
        </div>

        <div id="estadoVacio" class="estado-vacio d-none">
            <div class="estado-emoji">🗂️</div>
            <p class="mb-1"><strong>No hay personas registradas</strong></p>
            <p class="text-muted mb-0">Usa el botón «Nueva persona» para agregar la primera.</p>
        </div>

        <div id="estadoSinResultados" class="estado-vacio d-none">
            <div class="estado-emoji">🔍</div>
            <p class="mb-0 text-muted">No hay resultados para tu búsqueda.</p>
        </div>
    </div>
</div>

@* ---------- Modal Crear / Editar ---------- *@
<div class="modal fade" id="modalPersona" tabindex="-1" aria-labelledby="modalPersonaLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form id="formPersona" novalidate>
                <div class="modal-header">
                    <h5 class="modal-title" id="modalPersonaLabel">Nueva persona</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="Id" name="Id" value="0" />

                    <div class="mb-3">
                        <label for="Nombres" class="form-label">Nombres</label>
                        <input type="text" class="form-control" id="Nombres" name="Nombres" maxlength="150" />
                        <div class="invalid-feedback" data-field="Nombres"></div>
                    </div>

                    <div class="mb-3">
                        <label for="PrimerApellido" class="form-label">Primer Apellido</label>
                        <input type="text" class="form-control" id="PrimerApellido" name="PrimerApellido" maxlength="100" />
                        <div class="invalid-feedback" data-field="PrimerApellido"></div>
                    </div>

                    <div class="mb-3">
                        <label for="SegundoApellido" class="form-label">Segundo Apellido <span class="text-muted small">(opcional)</span></label>
                        <input type="text" class="form-control" id="SegundoApellido" name="SegundoApellido" maxlength="100" />
                        <div class="invalid-feedback" data-field="SegundoApellido"></div>
                    </div>

                    <div class="mb-3">
                        <label for="Direccion" class="form-label">Dirección</label>
                        <input type="text" class="form-control" id="Direccion" name="Direccion" maxlength="250" />
                        <div class="invalid-feedback" data-field="Direccion"></div>
                    </div>

                    <div class="mb-1">
                        <label for="Sexo" class="form-label">Sexo</label>
                        <select class="form-select" id="Sexo" name="Sexo">
                            <option value="">-- Seleccione --</option>
                            <option value="Masculino">Masculino</option>
                            <option value="Femenino">Femenino</option>
                        </select>
                        <div class="invalid-feedback" data-field="Sexo"></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary" id="btnGuardar">
                        <span class="spinner-border spinner-border-sm d-none" id="spinnerGuardar" role="status"></span>
                        <span id="txtGuardar">Guardar</span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@* ---------- Modal Confirmar eliminación ---------- *@
<div class="modal fade" id="modalEliminar" tabindex="-1" aria-labelledby="modalEliminarLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title text-danger" id="modalEliminarLabel">Eliminar persona</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2">¿Seguro que deseas eliminar este registro? Esta acción no se puede deshacer.</p>
                <p class="fw-semibold mb-0" id="nombreEliminar"></p>
                <input type="hidden" id="idEliminar" value="" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-danger" id="btnConfirmarEliminar">
                    <span class="spinner-border spinner-border-sm d-none" id="spinnerEliminar" role="status"></span>
                    <span id="txtEliminar">Eliminar</span>
                </button>
            </div>
        </div>
    </div>
</div>

@* ---------- Contenedor de notificaciones (toasts) ---------- *@
<div class="toast-container position-fixed bottom-0 end-0 p-3" id="toastContainer"></div>

@section Scripts {
    <script src="~/js/personas.js" asp-append-version="true"></script>
}
